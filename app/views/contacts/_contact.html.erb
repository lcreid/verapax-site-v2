<fieldset disabled class="border p-1 mb-2">
  <%= bootstrap_form_with(model: contact, url: false) do |message_form| %>
    <%= message_form.text_field(:name) %>
    <%= message_form.email_field(:email_address) %>
    <%= message_form.textarea(:message, wrapper_class: "mb-0") %>
  <% end %>
</fieldset>
